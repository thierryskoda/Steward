{
  "name": "steward-menubar",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "pnpm run build:electron && concurrently -k -n \"vite,tsc,electron\" -c \"blue,yellow,green\" \"vite\" \"tsc -p tsconfig.electron.json -w --preserveWatchOutput\" \"wait-on http://localhost:1420 && nodemon --watch dist-electron -e js --exec \\\"electron .\\\"\"",
    "build": "tsc && vite build",
    "build:electron": "rm -rf dist-electron && tsc -p tsconfig.electron.json && cp -r electron/icons dist-electron/",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test electron/registry.test.ts src/ui/shell-state.test.ts src/utils/query-keys.test.ts src/features/kanban/kanban-ui.store.test.ts"
  },
  "dependencies": {
    "@steward/contracts": "workspace:*",
    "@tanstack/react-query": "^5.62.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.35.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "concurrently": "^10.0.3",
    "electron": "^43.1.0",
    "nodemon": "^3.1.14",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vite": "^6.4.3",
    "wait-on": "^9.0.10"
  }
}

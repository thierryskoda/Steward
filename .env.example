# Optional overrides for runtime/agent. Not required for normal use; add/select/start project in Menubar Settings.
# Scripts/e2e pass project root when spawning the runtime; do not set project root here.

# --- Optional ---
# Cursor projects root for transcript discovery (default: ~/.cursor/projects)
# CTO_CURSOR_PROJECTS_ROOT=~/.cursor/projects

# Polling interval in ms for Cursor DB sources
CURSOR_POLL_INTERVAL_MS=5000

# LLM provider: cursor_cli (default), codex_cli, claude_code_cli, or antigravity_cli.
# antigravity_cli is recognized but currently unsupported for automated runtime execution.
# Invalid values fail startup.
# CTO_LLM_PROVIDER=cursor_cli

# Agent subprocess limits (strict timeouts + watchdog)
# AGENT_TIMEOUT_MS: hard max runtime (default 900000 = 15 min)
# AGENT_WATCHDOG_IDLE_MS: no stdout/stderr activity before idle timeout (default 600000 = 10 min)
# AGENT_KILL_GRACE_MS: wait after SIGTERM before SIGKILL (default 10000 = 10 s)
# AGENT_TIMEOUT_MS=900000
# AGENT_WATCHDOG_IDLE_MS=600000
# AGENT_KILL_GRACE_MS=10000
# CTO_AGENT_MAX_CONCURRENCY=3

# HTTP port for runtime. 0 = dynamic (default); runtime picks a free port and writes it to per-project endpoint.json. Set a fixed port if needed.
# CTO_HTTP_PORT=0

# Stale implementing recovery threshold in ms (default 1200000 = 20 min).
# CTO_IMPLEMENTING_STALE_MS=1200000

# Agent queue max wait before rejecting request, ms (default 600000 = 10 min).
# CTO_AGENT_MAX_QUEUE_AGE_MS=600000

# Agent queue wait threshold for "queue warn wait" log, ms (default 30000 = 30 s).
# CTO_AGENT_QUEUE_WARN_WAIT_MS=30000

# Optional debug transport (when both set, runtime sends debug events)
# CTO_DEBUG_ENDPOINT=http://127.0.0.1:7710/ingest/your-session-id
# CTO_DEBUG_SESSION=your-session-id

# Optional runtime logs root (default: ~/.steward/logs)
# CTO_LOGS_ROOT=/Users/you/.steward/logs

# Agent I/O logging. Valid values: true | false. When true, writes prompt/response JSON to <logsRoot>/agents/<agentId>/
# CTO_AGENT_IO_LOG_ENABLED=false

# When true, runtime regenerates the generated exclude snapshot in .steward/state.db on git structure changes.
# CTO_REGENERATE_CONFIG_ON_GIT_POLL=true

# Git poll: wait this many ms of stable hash before running proactive finding (default 60000 = 60 s).
# CTO_GIT_POLL_QUIET_WINDOW_MS=60000

# Flow toggles (transcript watch, rules workflow, generic finding, continual learning, etc.) are controlled per project
# in .steward/state.db project_config "features". Use Menubar Settings to change them; restart runtime to apply.
